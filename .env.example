# DHIS2 API credentials (required for both cleanup and sync)
DHIS2_URL=https://cpmis.gender.gov.mw
DHIS2_USERNAME=your_username
DHIS2_PASSWORD=your_password

# PostgreSQL credentials (optional — only needed for cleanup --use-db)
DB_HOST=your_database_host
DB_PORT=5433
DB_NAME=cpmis_copy_clone
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# Sync settings (optional — only needed for sync rescue)
# DHIS2_SERVER defaults to DHIS2_URL if not set
# DHIS2_SERVER=https://cpmis.gender.gov.mw
# BATCH_SIZE=200
